{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://makoto.dev/schema/transform/v0.1",
  "title": "Makoto Transform Attestation",
  "description": "in-toto Statement v1 with makoto.dev/transform/v1 predicate. Documents data transformations.",
  "type": "object",
  "required": ["_type", "subject", "predicateType", "predicate"],
  "properties": {
    "_type": {
      "type": "string",
      "const": "https://in-toto.io/Statement/v1"
    },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "digest"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Identifier for the output data artifact"
          },
          "digest": {
            "type": "object",
            "required": ["sha256"],
            "properties": {
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "recordCount": { "type": "string" }
            }
          }
        }
      }
    },
    "predicateType": {
      "type": "string",
      "const": "https://makoto.dev/transform/v1"
    },
    "predicate": {
      "type": "object",
      "required": ["inputs", "transform"],
      "properties": {
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "digest"],
            "properties": {
              "name": { "type": "string" },
              "digest": {
                "type": "object",
                "required": ["sha256"],
                "properties": {
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                }
              },
              "attestationRef": { "type": "string", "description": "URI or path to the input's attestation" }
            }
          }
        },
        "transform": {
          "type": "object",
          "required": ["type", "name"],
          "properties": {
            "type": { "type": "string", "description": "Transform type URI (e.g., https://makoto.dev/transforms/filter)" },
            "name": { "type": "string", "description": "Human-readable name of the transformation" },
            "version": { "type": "string" },
            "parameters": {
              "type": "object",
              "additionalProperties": true,
              "description": "Configuration used for this transformation"
            },
            "codeRef": {
              "type": "object",
              "properties": {
                "uri": { "type": "string", "description": "Git reference to the transformation code" },
                "digest": {
                  "type": "object",
                  "properties": {
                    "sha256": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "executor": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "description": "Identifier of the system that executed the transformation" },
            "platform": { "type": "string" }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "startedOn": { "type": "string", "format": "date-time" },
            "finishedOn": { "type": "string", "format": "date-time" },
            "recordsInput": { "type": "integer" },
            "recordsOutput": { "type": "integer" }
          }
        }
      }
    }
  }
}
