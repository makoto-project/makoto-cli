{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://makoto.dev/schema/origin/v0.1",
  "title": "Makoto Origin Attestation",
  "description": "in-toto Statement v1 with makoto.dev/origin/v1 predicate. Documents where data came from.",
  "type": "object",
  "required": ["_type", "subject", "predicateType", "predicate"],
  "properties": {
    "_type": {
      "type": "string",
      "const": "https://in-toto.io/Statement/v1"
    },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "digest"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Identifier for the data artifact (e.g., dataset:customer_transactions)"
          },
          "digest": {
            "type": "object",
            "required": ["sha256"],
            "properties": {
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "recordCount": { "type": "string" },
              "merkleRoot": { "type": "string" }
            }
          }
        }
      }
    },
    "predicateType": {
      "type": "string",
      "const": "https://makoto.dev/origin/v1"
    },
    "predicate": {
      "type": "object",
      "required": ["origin"],
      "properties": {
        "origin": {
          "type": "object",
          "required": ["source", "sourceType"],
          "properties": {
            "source": { "type": "string", "description": "URI identifying the data source" },
            "sourceType": { "type": "string", "description": "Type of source (e.g., api, file, database, iot-device)" },
            "collectionMethod": { "type": "string", "description": "How data was collected (e.g., scheduled-pull, manual-upload)" },
            "collectionTimestamp": { "type": "string", "format": "date-time" },
            "geography": { "type": "string", "description": "Geographic region where data was collected" },
            "consent": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "reference": { "type": "string" }
              }
            }
          }
        },
        "collector": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "description": "Identifier of the system that collected the data" },
            "version": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "schema": {
          "type": "object",
          "properties": {
            "format": { "type": "string", "description": "Data format (e.g., csv, json, parquet)" },
            "schemaRef": { "type": "string", "description": "URI to the data schema" }
          }
        }
      }
    }
  }
}
